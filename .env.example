OPENAI_API_KEY=你的真实key
OPENAI_MODEL=qwen3.6-flash
OPENAI_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

FAQ_TOP_K=8
FAQ_MIN_SCORE=0.05
# 语义检索所用的 embedding 模型，用于识别措辞不同但意思相同的相似问题
FAQ_EMBED_MODEL=text-embedding-v3
APP_PORT=8000

# ---- 三种工作模式 & 客服工作台 ----

# JWT 签名密钥（客服登录鉴权用，务必修改为随机字符串）
JWT_SECRET=change_this_to_a_random_secret_string

# 首次启动自动创建的管理员账号（请登录后立即修改密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password

# 系统首次启动时的默认模式：auto(全AI) / manual(全人工) / collab(人机协同)
DEFAULT_MODE=auto

# ---- 邮件提醒（问题转人工时提醒客服/管理员） ----
# 未配置 SMTP_HOST 时会跳过发送并只打印警告日志，不影响其余功能。
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=你的发信账号
SMTP_PASSWORD=你的发信密码或应用专用密码
SMTP_FROM=你的发信账号
# 是否使用 STARTTLS（大多数服务商用 587 端口时为 true）；如果用 465 端口的 SSL，改用 SMTP_USE_SSL=true
SMTP_USE_TLS=true
SMTP_USE_SSL=false
# 收件邮箱，可用逗号分隔多个；测试阶段先发到测试邮箱
NOTIFY_EMAIL_TO=yunitechhk@gmail.com
